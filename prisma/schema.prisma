// The Distribution Lab — Client OS data model
//
// Provider is SQLite for local dev. To deploy on Postgres, change
// `provider` to "postgresql" and point DATABASE_URL at your database.
// The model is written to be portable (no SQLite-only or PG-only features).

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // "native" for local dev; rhel target is the runtime Vercel uses.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for the app.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by `prisma migrate`.
  directUrl = env("DIRECT_URL")
}

// Roles: "admin" | "intern" | "client"
// Statuses are stored as strings (see src/lib/constants.ts) to stay
// portable across databases and easy to extend.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  initials     String
  role         String // admin | intern | client
  subtitle     String? // e.g. "Founder · Admin"

  // Intern-only: may this intern edit client deliverables?
  canEdit Boolean @default(false)

  // role=client → the client record this user signs in to
  clientProfile Client? @relation("ClientPortalUser")

  // role=intern → clients this intern may access + tasks assigned
  internAccess InternClientAccess[]
  tasks        Task[]

  authoredNotes Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Client {
  id       String @id @default(cuid())
  name     String
  initials String
  service  String
  tenure   String

  // Optional portal login for this client
  portalUserId String? @unique
  portalUser   User?   @relation("ClientPortalUser", fields: [portalUserId], references: [id], onDelete: SetNull)

  deliverables   Deliverable[]
  notes          Note[]
  prospects      Prospect[]
  tasks          Task[]
  internAccess   InternClientAccess[]
  dailyActivities DailyActivity[]
  finance        ClientFinance?
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Admin-only money ledger for a client (never shown to interns/clients). */
model ClientFinance {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  currency       String  @default("USD")
  projected      Float   @default(0) // total contract value
  received       Float   @default(0) // how much has come in
  startDate      String? // 'YYYY-MM-DD'
  endDate        String?
  notes          String?
  billingAddress String? // remembered bill-to address, auto-fills invoices

  updatedAt DateTime @updatedAt
}

/** A stored, generatable invoice (admin-only). items = [{description, qty, rate}]. */
model Invoice {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  number    String
  issueDate String // 'YYYY-MM-DD'
  dueDate   String?
  status    String  @default("Draft") // Draft | Sent | Paid
  currency  String  @default("USD")
  items     Json
  notes     String?

  // Bill-to snapshot
  billToName    String?
  billToEmail   String?
  billToAddress String?

  // Money breakdown
  discount Float  @default(0) // flat amount off the subtotal
  taxLabel String @default("Tax") // e.g. GST / VAT
  taxRate  Float  @default(0) // percent

  poNumber     String?
  paymentTerms String?

  createdAt DateTime @default(now())

  @@index([clientId])
}

/** A recurring daily quota for a client (e.g. "Comments" · 20/day). */
model DailyActivity {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  unit        String? // e.g. "comments", "posts", "connections"
  dailyTarget Int     @default(1)

  logs      DailyLog[]
  createdAt DateTime @default(now())

  @@index([clientId])
}

/** How many of an activity were done on a given day ('YYYY-MM-DD'). */
model DailyLog {
  id         String        @id @default(cuid())
  activityId String
  activity   DailyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  date  String // 'YYYY-MM-DD'
  count Int    @default(0)

  @@unique([activityId, date])
  @@index([activityId])
}

model Deliverable {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name   String
  due    String @default("Due —")
  status String @default("Not Started") // Not Started | In Progress | Done | Delayed

  createdAt DateTime @default(now())

  @@index([clientId])
}

model Note {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Author is denormalised so notes survive author deletion / system authors.
  authorUserId   String?
  authorUser     User?   @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  authorName     String
  authorInitials String

  text      String
  timeLabel String @default("") // human label shown in UI (e.g. "Jun 18", "Just now")

  createdAt DateTime @default(now())

  @@index([clientId])
}

model Task {
  id       String @id @default(cuid())
  internId String
  intern   User   @relation(fields: [internId], references: [id], onDelete: Cascade)

  // null = personal task (not tied to a client)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  title  String
  due    String @default("—")
  status String @default("Not Started") // Not Started | In Progress | Done | Delayed

  // Optional quantitative target, e.g. 12 blogs / 30 comments.
  // When targetCount is set, progress % = doneCount / targetCount.
  unit        String? // label for the count, e.g. "blogs", "comments"
  targetCount Int?
  doneCount   Int?

  createdAt DateTime @default(now())

  @@index([internId])
}

model InternClientAccess {
  id       String @id @default(cuid())
  internId String
  clientId String

  intern User   @relation(fields: [internId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([internId, clientId])
  @@index([clientId])
}

model Prospect {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  channel String @default("linkedin") // linkedin | email
  name    String @default("")
  url     String @default("")
  email   String @default("")
  role    String @default("")
  company String @default("")
  status  String @default("Connection Request Sent")
  notes   String @default("")
  dateLabel String @default("")

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([channel])
}
